go 1.26.0

use .

replace github.com/vantaboard/go-googlesql => ../go-googlesql
replace github.com/vantaboard/go-googlesql/lib/darwin-amd64 => ../go-googlesql/lib/darwin-amd64
replace github.com/vantaboard/go-googlesql/lib/darwin-arm64 => ../go-googlesql/lib/darwin-arm64
replace github.com/vantaboard/go-googlesql/lib/linux-amd64 => ../go-googlesql/lib/linux-amd64
replace github.com/vantaboard/go-googlesql/lib/linux-arm64 => ../go-googlesql/lib/linux-arm64
replace github.com/vantaboard/go-googlesql/lib/windows-amd64 => ../go-googlesql/lib/windows-amd64

// Copy to go.work for local development with a sibling go-googlesql checkout.
// Replace lives here (not in go.mod); `go mod` / CI without a workspace resolve the released module version.
